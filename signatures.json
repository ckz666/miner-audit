{
  "_description": "Passive fingerprint signatures for ASIC miners. Used only for identification, no authentication attempted.",
  "miners": [
    {
      "id": "antminer",
      "vendor": "Bitmain",
      "models": ["S9", "S17", "S19", "S19j", "S19 XP", "S21", "T19", "L7", "DR5", "Z15"],
      "http_paths": ["/", "/cgi-bin/get_system_info.cgi", "/cgi-bin/get_miner_conf.cgi"],
      "title_patterns": ["Antminer", "antMiner", "ANTMINER"],
      "body_patterns": ["Antminer", "cgminer", "bmminer", "Bitmain"],
      "common_ports": [80, 443],
      "auth_indicator_path": "/cgi-bin/get_system_info.cgi",
      "firmware_extraction": {
        "path": "/",
        "regex": "[vV]ersion[:\"\\s]*([0-9]{4}[0-9]{2}[0-9]{2}|[0-9]+\\.[0-9]+\\.[0-9]+)",
        "note": "Antminer stock firmware embeds date in page or via /cgi-bin/get_system_info.cgi"
      }
    },
    {
